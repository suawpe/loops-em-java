void main() {
    Scanner sc = new Scanner(System.in);
    int numeroCorreto = 7;
    int tentativa = 0;


    while (tentativa != numeroCorreto) {
        IO.println("Tente adivinhar o número (1-10): ");
        tentativa = sc.nextInt();

        if (tentativa != numeroCorreto) {
            IO.println("Errado! Tente novamente");
        }
    }

    IO.println("Parabéns!" Você acertou!!");

}
